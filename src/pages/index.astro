---
import Layout from '../layouts/Layout.astro';
import { ResumeRedirect } from '../components/atoms/ResumeRedirect';
---

<Layout>
  <ResumeRedirect client:load />
  <main class="min-h-screen bg-slate-50 relative overflow-hidden flex flex-col items-center justify-center p-4">
    <div class="bg-white/80 backdrop-blur-xl rounded-2xl border border-white/50 shadow-lg p-6 sm:p-8 max-w-md w-full text-center space-y-6">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-slate-900 drop-shadow-sm">
        OurPlan
      </h1>
      <p class="text-sm sm:text-base text-slate-600 max-w-sm mx-auto">
        A calm, conversational way to build a complete care plan for an older loved one &mdash; together.
      </p>
      <a
        href="/step1"
        class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-[color,box-shadow] disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/20 h-9 px-4 py-2 has-[>svg]:px-3 bg-slate-900 text-white shadow hover:bg-slate-800 focus-visible:ring-[#fe676e]"
      >
        Start your plan
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </main>
</Layout>
