---
import Layout from '../layouts/Layout.astro';
import { ValidatedInput } from '@/components/atoms/ValidatedInput';
import { ParentHealthRadioGroup } from '@/components/molecules/ParentHealthRadioGroup';
---

<Layout>
  <div class="min-h-screen bg-slate-50 relative overflow-hidden flex flex-col justify-center">
    <!-- Decorative background elements -->
    <div class="absolute top-0 -left-4 w-72 h-72 bg-[#fe676e]/20 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob"></div>
    <div class="absolute top-0 -right-4 w-72 h-72 bg-orange-300/30 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 left-20 w-72 h-72 bg-[#fe676e]/30 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-4000"></div>

    <main class="relative z-10 py-8 px-4 sm:py-12 sm:px-6 lg:px-8 w-full">
      <div class="max-w-xl mx-auto w-full">
        <div class="mb-8 text-center space-y-3">
          <div class="inline-flex items-center rounded-full border border-[#fe676e]/20 bg-white/60 px-3 py-1 text-xs font-medium text-[#fe676e] backdrop-blur-sm shadow-sm">
            <span class="flex h-1.5 w-1.5 rounded-full bg-[#fe676e] mr-2"></span>
            Step 1 of 4
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-slate-900 drop-shadow-sm">
            Core Identities
          </h1>
          <p class="text-sm sm:text-base text-slate-600 max-w-md mx-auto">
            Let's start with some basic information so we can personalise your plan beautifully.
          </p>
        </div>
        
        <div class="bg-white/80 backdrop-blur-xl rounded-2xl border border-white/50 shadow-lg p-6 sm:p-8 transition-all duration-300 w-full">
          
          <!-- Static form container in Astro -->
          <div class="space-y-6 w-full">
            
            <!-- React Atoms instantiated directly in Astro -->
            <div class="w-full">
              <ValidatedInput 
                field="user_name" 
                label="First, what is your name?" 
                placeholder="e.g., Sarah"
                client:load
              />
            </div>

            <div class="w-full">
              <ValidatedInput 
                field="parent_name" 
                label="Who are we planning for today?" 
                placeholder="e.g., Mum, Dad, John & Rita"
                client:load
              />
            </div>

            <div class="w-full">
              <!-- Molecule used for dynamic labeling -->
              <ParentHealthRadioGroup client:load />
            </div>

            <!-- Static Astro UI elements for Footer/Action -->
            <div class="pt-6 mt-6 border-t border-slate-100 flex flex-col sm:flex-row items-center justify-between gap-4">
              <p class="text-sm text-slate-500">Your progress is saved automatically.</p>
              <a 
                href="/step-2" 
                class="w-full sm:w-auto inline-flex items-center justify-center rounded-md bg-slate-900 px-6 py-2.5 text-sm font-medium text-white shadow hover:bg-slate-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#fe676e] transition-colors"
              >
                Continue
                <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>

          </div>

        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
