---
import StepLayout from '../layouts/StepLayout.astro';
import { DynamicLabelRadioGroup } from '../components/molecules/DynamicLabelRadioGroup';
---

<StepLayout
  title="Systemic Safeguards"
  subtitle="Help us understand what safeguards matter most."
  stepPath="/step2"
  backUrl="/step1"
>
  <div class="space-y-6">
    <DynamicLabelRadioGroup
      client:load
      field="lpa_status"
      labelTemplate="Do you have Lasting Power of Attorney (LPA) registered for {parent_name}?"
      labelFields={["parent_name"]}
      fallbackLabel="Do you have Lasting Power of Attorney (LPA) registered for your loved one?"
      options={[
        { value: 'both', label: 'Yes, both Health & Welfare and Financial.' },
        { value: 'one', label: 'Just one of them (either Health or Financial).' },
        { value: 'started', label: 'We’ve talked about it, but nothing is legally active yet.' },
        { value: 'none', label: 'No, and I don\'t know how to bring it up.' },
      ]}
    />

    <DynamicLabelRadioGroup
      client:load
      field="psr_status"
      labelTemplate="Is {parent_name} registered on the utility Priority Services Register (PSR)?"
      labelFields={["parent_name"]}
      fallbackLabel="Is your loved one registered on the utility Priority Services Register (PSR)?"
      options={[
        { value: 'yes', label: 'Yes, all sorted.' },
        { value: 'no', label: 'No, or I haven\'t heard of this yet.' },
      ]}
    />

    <DynamicLabelRadioGroup
      client:load
      field="documents_loc"
      labelTemplate="If there was an emergency tomorrow, do you know exactly where {parent_name} keeps their vital documents (Will, NHS number, insurance)?"
      labelFields={["parent_name"]}
      fallbackLabel="If there was an emergency tomorrow, do you know exactly where they keep their vital documents (Will, NHS number, insurance)?"
      options={[
        { value: 'yes', label: 'Yes, I know exactly where the folder/drawer is.' },
        { value: 'partial', label: 'I have a rough idea, but it would take some hunting.' },
        { value: 'no', label: 'No clue—it\'s a complete mystery.' },
      ]}
    />
  </div>
</StepLayout>
