---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-lg border border-slate-100 p-8 text-center space-y-6">
      <div class="inline-flex items-center rounded-full border border-[#fe676e]/20 bg-[#fe676e]/5 px-3 py-1 text-xs font-medium text-[#fe676e]">
        <span class="flex h-1.5 w-1.5 rounded-full bg-[#fe676e] mr-2"></span>
        Step 2 of 4
      </div>
      
      <h1 class="text-3xl font-bold text-slate-900">Systemic Safeguards</h1>
      <p class="text-slate-600 text-sm">
        This is a dummy placeholder page. Feel free to use the browser back button or the link below to test if your form data from Step 1 was persisted successfully!
      </p>
      
      <div class="pt-6 border-t border-slate-100">
        <a 
          href="/first-step" 
          class="inline-flex items-center text-[#fe676e] font-medium hover:underline"
        >
          <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Go Back to Step 1
        </a>
      </div>
    </div>
  </div>
</Layout>
