---
import Layout from '../layouts/Layout.astro';
import { CodeInput } from '../components/atoms/CodeInput';
import { TermsCheckbox } from '../components/atoms/TermsCheckbox';
import { VerifyButton } from '../components/atoms/VerifyButton';
import { ApiError } from '../components/atoms/ApiError';
---

<Layout>
  <main class="min-h-screen bg-slate-50 relative overflow-hidden flex flex-col items-center justify-center p-4">
    <!-- Decorative background elements -->
    <div class="absolute top-0 -left-4 w-72 h-72 bg-[#fe676e]/20 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob"></div>
    <div class="absolute top-0 -right-4 w-72 h-72 bg-orange-300/30 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 left-20 w-72 h-72 bg-[#fe676e]/30 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-4000"></div>

    <div class="relative z-10 bg-white/80 backdrop-blur-xl rounded-2xl border border-white/50 shadow-lg p-6 sm:p-8 max-w-md w-full text-center space-y-6">
      <div class="flex flex-col items-center space-y-3">
        <img
          src="/ourplan-logo.png"
          alt="OurPlan"
          class="h-16 w-auto"
        />
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-slate-900 drop-shadow-sm">
          OurPlan
        </h1>
      </div>

      <p class="text-sm sm:text-base text-slate-600 max-w-sm mx-auto">
        Enter your invitation code to get started.
      </p>

      <div class="space-y-2 w-full text-left">
        <CodeInput client:load />

        <TermsCheckbox client:load />

        <p class="px-2 text-xs text-slate-400 leading-relaxed">
          By entering your invitation code and accepting the terms, you agree that this tool provides
          informational guidance and does not replace professional legal, financial, or medical advice.
        </p>
      </div>

      <div class="w-full">
        <ApiError client:load />
        <VerifyButton client:load />
      </div>
    </div>
  </main>
</Layout>

<style>
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
