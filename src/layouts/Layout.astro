---
import '../styles/global.css'
import { ProgressBar } from '../components/atoms/ProgressBar';
import { GlobalLoader } from '../components/molecules/GlobalLoader';

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en" style="color-scheme: light;">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<meta name="theme-color" content="#dd4d57" />
		<meta name="description" content="Estate planning made simple" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="OurPlan" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>OurPlan — Estate Planning Made Simple</title>
	</head>
	<body style="touch-action: manipulation;">
		<GlobalLoader client:load />
		<ProgressBar currentPath={pathname} client:load />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
