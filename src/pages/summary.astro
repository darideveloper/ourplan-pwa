---
import Layout from '../layouts/Layout.astro';
import { StepGuard } from '../hooks/useStepGuard';
---

<Layout>
  <StepGuard client:load />
  <div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-4">
    <div class="max-w-md w-full mb-4">
      <a href="/step4" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back
      </a>
    </div>
    <div class="max-w-md w-full bg-white rounded-2xl shadow-lg border border-slate-100 p-8 text-center space-y-6">
      <h1 class="text-3xl font-bold text-slate-900">Review Your Plan</h1>
      <p class="text-slate-600 text-sm">
        Summary content coming soon.
      </p>
    </div>
  </div>
</Layout>
