---
import StepLayout from '../layouts/StepLayout.astro';
import { SummaryReviewCard } from '@/components/organisms/SummaryReviewCard';
import { DisclaimerCheckbox } from '@/components/atoms/DisclaimerCheckbox';
import { SummarySubmitButton } from '@/components/atoms/SummarySubmitButton';
---

<StepLayout
    title="Review Your Plan"
    subtitle="Review the details you've provided before generating your plan."
    stepPath="/summary"
    backUrl="/step4"
    hideContinue={true}
>
    <div class="space-y-6">
      <SummaryReviewCard client:load />
      
      <div class="bg-white/60 rounded-xl shadow-sm border border-slate-100 p-6 space-y-6">
        <h2 class="text-xl font-semibold text-slate-900">Final Step</h2>
        <DisclaimerCheckbox client:load />
        <SummarySubmitButton client:load />
      </div>
    </div>
</StepLayout>
