---
import Layout from '../layouts/Layout.astro';
import { StepGuard } from '../hooks/useStepGuard';
---

<Layout>
  <StepGuard client:load />
  <div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-lg border border-slate-100 p-8 text-center space-y-6">
      <h1 class="text-3xl font-bold text-slate-900">Review Your Plan</h1>
      <p class="text-slate-600 text-sm">
        Summary content coming soon.
      </p>
    </div>
  </div>
</Layout>
