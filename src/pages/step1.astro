---
import StepLayout from '../layouts/StepLayout.astro';
import { ValidatedInput } from '@/components/atoms/ValidatedInput';
import { ParentHealthRadioGroup } from '@/components/molecules/ParentHealthRadioGroup';
---

<StepLayout
  title="Core Identities"
  subtitle="Let's start with some basic information so we can personalise your plan beautifully."
  stepPath="/step1"
>
  <div class="w-full">
    <ValidatedInput
      field="user_name"
      label="First, what is your name?"
      placeholder="e.g., Sarah"
      client:load
    />
  </div>

  <div class="w-full">
    <ValidatedInput
      field="parent_name"
      label="Who are we planning for today?"
      placeholder="e.g., Mum, Dad, John & Rita"
      client:load
    />
  </div>

  <div class="w-full">
    <ParentHealthRadioGroup client:load />
  </div>
</StepLayout>
